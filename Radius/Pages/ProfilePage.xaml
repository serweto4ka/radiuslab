<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Radius.Pages.ProfilePage"
             Title="Мій профіль">
    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="12">
            <Label Text="Мій профіль"
                   FontSize="26"
                   FontAttributes="Bold" />
            <Entry x:Name="NameEntry" Placeholder="Ім'я" />
            <Entry x:Name="PhoneEntry" Placeholder="Телефон" Keyboard="Telephone" />
            <Entry x:Name="EmailEntry" Placeholder="Email" Keyboard="Email" />
            <Button Text="Зберегти зміни" Clicked="OnSaveClicked" />
            <Label x:Name="StatsLabel" />
            <Button Text="Вийти з акаунту"
                    Clicked="OnLogoutClicked"
                    BackgroundColor="#B91C1C"
                    TextColor="White" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
