<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Radius.Pages.VehiclesPage"
             Title="Авто">
    <VerticalStackLayout Padding="24" Spacing="12">
        <Label Text="Мої автомобілі"
               FontSize="24"
               FontAttributes="Bold" />
        <CollectionView x:Name="VehiclesCollection" HeightRequest="220">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Margin="0,4">
                        <Label Text="{Binding}" />
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
        <Entry x:Name="BrandEntry" Placeholder="Додати марку" />
        <Entry x:Name="ModelEntry" Placeholder="Додати модель" />
        <Entry x:Name="PlateEntry" Placeholder="Держномер" />
        <Button Text="Додати авто" Clicked="OnAddVehicleClicked" />
    </VerticalStackLayout>
</ContentPage>
