<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Radius.Pages.ServicesPage"
             Title="Послуги">
    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="12">
            <Label Text="Каталог послуг"
                   FontSize="24"
                   FontAttributes="Bold" />
            <Frame><Label Text="Заміна 4 шин — 900 грн" /></Frame>
            <Frame><Label Text="Балансування 4 коліс — 600 грн" /></Frame>
            <Frame><Label Text="Ремонт проколу — від 250 грн" /></Frame>
            <Frame><Label Text="Перевірка/підкачка тиску — 150 грн" /></Frame>
            <Frame><Label Text="Сезонне зберігання комплекту — 1400 грн/сезон" /></Frame>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
