<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Radius.Pages.AppointmentDetailsPage"
             Title="Деталі">
    <VerticalStackLayout Padding="24" Spacing="10">
        <Label Text="Детальна сторінка запису"
               FontSize="24"
               FontAttributes="Bold" />
        <Label x:Name="ClientLabel" />
        <Label x:Name="CarLabel" />
        <Label x:Name="ServiceLabel" />
        <Label x:Name="DateLabel" />
        <Label x:Name="CostLabel" />
        <Label x:Name="StatusLabel" FontAttributes="Bold" />
        <Editor x:Name="DescriptionEditor" HeightRequest="110" />
        <Button Text="Скасувати запис" Clicked="OnCancelClicked" />
        <Button Text="Позначити як виконаний" Clicked="OnCompleteClicked" />
    </VerticalStackLayout>
</ContentPage>
