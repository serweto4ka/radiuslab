<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Radius.Pages.ReviewsPage"
             Title="Відгуки">
    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="12">
            <Label Text="Відгуки клієнтів"
                   FontSize="24"
                   FontAttributes="Bold" />
            <Frame>
                <VerticalStackLayout>
                    <Label Text="★★★★★" />
                    <Label Text="Дуже швидко й акуратно, запис онлайн спрацював без проблем." />
                </VerticalStackLayout>
            </Frame>
            <Frame>
                <VerticalStackLayout>
                    <Label Text="★★★★☆" />
                    <Label Text="Зручно, що видно всі вільні вікна на сьогодні." />
                </VerticalStackLayout>
            </Frame>
            <Editor Placeholder="Залишити відгук..." HeightRequest="120" />
            <Button Text="Надіслати відгук" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
